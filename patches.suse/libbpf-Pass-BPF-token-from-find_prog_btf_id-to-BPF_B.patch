@@ -10127,7 +10127,7 @@ static int libbpf_find_attach_btf_id(str
 			pr_warn("prog '%s': attach program FD is not set\n", prog->name);
 			return -EINVAL;
 		}
-		err = libbpf_find_prog_btf_id(attach_name, attach_prog_fd);
