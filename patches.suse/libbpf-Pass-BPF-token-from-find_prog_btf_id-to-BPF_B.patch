@@ -12923,7 +12923,7 @@ struct bpf_link *bpf_program__attach_fre
 	if (target_fd) {
 		LIBBPF_OPTS(bpf_link_create_opts, target_opts);
 
-		btf_id = libbpf_find_prog_btf_id(attach_func_name, target_fd);
