@@ -59,7 +59,6 @@ static const struct iwl_base_params iwl_sc_base_params = {
 	.ucode_api_max = IWL_SC_UCODE_API_MAX,				\
 	.ucode_api_min = IWL_SC_UCODE_API_MIN,				\
 	.led_mode = IWL_LED_RF_STATE,					\
