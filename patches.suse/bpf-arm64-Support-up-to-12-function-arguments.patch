 	emit(A64_STR64I(A64_R(19), A64_SP, regs_off), ctx);
@@ -2369,7 +2483,7 @@ static int prepare_trampoline(struct jit
 	}
 
 	for (i = 0; i < fentry->nr_links; i++)
