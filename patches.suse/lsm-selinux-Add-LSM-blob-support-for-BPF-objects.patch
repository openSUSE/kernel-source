 		ret = avc_has_perm(sid, bpfsec->sid, SECCLASS_BPF,
 				   BPF__PROG_RUN, NULL);
 		if (ret)
@@ -6874,7 +6874,7 @@ static int selinux_bpf_map(struct bpf_ma
 	u32 sid = current_sid();
