From e3f3a1aea8719ac76bb9443bc3abc975250e1f98 Mon Sep 17 00:00:00 2001
From: Luiz Augusto von Dentz <luiz.von.dentz@intel.com>
Date: Wed, 1 Dec 2021 10:54:54 -0800
Subject: [PATCH] Bluetooth: HCI: Use skb_pull_data to parse Command Complete
 event
Git-commit: e3f3a1aea8719ac76bb9443bc3abc975250e1f98
References: CVE-2026-31771 bsc#1264145
Patch-mainline: v5.17-rc1

This uses skb_pull_data to check the Command Complete events received
have the minimum required length.

Signed-off-by: Luiz Augusto von Dentz <luiz.von.dentz@intel.com>
Signed-off-by: Marcel Holtmann <marcel@holtmann.org>
Signed-off-by: Oliver Neukum <oneukum@suse.com>

---
 net/bluetooth/hci_event.c |  886 +++++++++++++++++++++++++++++++++-------------
 1 file changed, 648 insertions(+), 238 deletions(-)

--- a/net/bluetooth/hci_event.c
+++ b/net/bluetooth/hci_event.c
@@ -56,12 +56,28 @@ static void *hci_ev_skb_pull(struct hci_
 	return data;
 }
 
+static void *hci_cc_skb_pull(struct hci_dev *hdev, struct sk_buff *skb,
+			     u16 op, size_t len)
+{
+	void *data;
+
+	data = skb_pull_data(skb, len);
+	if (!data)
+		bt_dev_err(hdev, "Malformed Command Complete: 0x%4.4x", op);
+
+	return data;
+}
