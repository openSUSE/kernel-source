From: Shung-Hsi Yu <shung-hsi.yu@suse.com>
Date: Tue, 01 Fed 2022 08:43:36 +0800
Subject: [PATCH] kABI padding for bpf
Patch-mainline: Never, kABI padding
References: bsc#1179531

Add kABI padding to important BPF types

Signed-off-by: Shung-Hsi Yu <shung-hsi.yu@suse.com>
---
 include/linux/bpf.h           |    4 ++++
 include/linux/bpf_mem_alloc.h |    1 +
 include/linux/bpf_mprog.h     |    1 +
 include/linux/bpf_verifier.h  |    5 +++++
 include/linux/hid_bpf.h       |    1 +
 5 files changed, 12 insertions(+)

--- a/include/linux/bpf.h
+++ b/include/linux/bpf.h
@@ -334,6 +334,7 @@
 	atomic64_t sleepable_refcnt;
 	s64 __percpu *elem_count;
 	u64 cookie; /* write-once */
+	void *suse_kabi_padding;
 };
 
 static inline const char *btf_field_type_name(enum btf_field_type type)
@@ -1671,6 +1672,7 @@
 		struct work_struct work;
 		struct rcu_head	rcu;
 	};
+	void *suse_kabi_padding;
 };
 
 struct bpf_prog {
@@ -1701,6 +1703,7 @@
 					    const struct bpf_insn *insn);
 	struct bpf_prog_aux	*aux;		/* Auxiliary fields */
 	struct sock_fprog_kern	*orig_prog;	/* Original BPF program */
+	void			*suse_kabi_padding;
 	/* Instructions for interpreter */
 	union {
 		DECLARE_FLEX_ARRAY(struct sock_filter, insns);
@@ -1738,6 +1741,7 @@
 	 * link's semantics is determined by target attach hook
 	 */
 	bool sleepable;
+	void *suse_kabi_padding;
 };
 
 struct bpf_link_ops {
--- a/include/linux/bpf_mem_alloc.h
+++ b/include/linux/bpf_mem_alloc.h
@@ -14,6 +14,7 @@
 	struct obj_cgroup *objcg;
 	bool percpu;
 	struct work_struct work;
+	void *suse_kabi_padding;
 };
 
 /* 'size != 0' is for bpf_mem_alloc which manages fixed-size objects.
--- a/include/linux/bpf_mprog.h
+++ b/include/linux/bpf_mprog.h
@@ -148,6 +148,7 @@
 	struct bpf_prog *ref;
 	atomic64_t revision;
 	u32 count;
+	void *suse_kabi_padding;
 };
 
 struct bpf_tuple {
--- a/include/linux/bpf_verifier.h
+++ b/include/linux/bpf_verifier.h
@@ -204,6 +204,7 @@
 	s32 subreg_def;
 	/* if (!precise && SCALAR_VALUE) min/max/tnum don't affect safety */
 	bool precise;
+	void *suse_kabi_padding;
 };
 
 enum bpf_stack_slot_type {
@@ -439,6 +440,7 @@
 	u32 dfs_depth;
 	u32 callback_unroll_depth;
 	u32 may_goto_depth;
+	void *suse_kabi_padding;
 };
 
 #define bpf_get_spilled_reg(slot, frame, mask)				\
@@ -590,6 +592,7 @@
 	u32 scc;
 	/* registers alive before this instruction. */
 	u16 live_regs_before;
+	void *suse_kabi_padding;
 };
 
 #define MAX_USED_MAPS 64 /* max number of maps accessed by one eBPF program */
@@ -613,6 +616,7 @@
 	u32 len_total;
 	u32 len_max;
 	char kbuf[BPF_VERIFIER_TMP_LOG_SIZE];
+	void *suse_kabi_padding;
 };
 
 #define BPF_LOG_LEVEL1	1
@@ -838,6 +842,7 @@
 	struct bpf_scc_info **scc_info;
 	u32 scc_cnt;
 	struct bpf_iarray *succ;
+	void *suse_kabi_padding;
 };
 
 static inline struct bpf_func_info_aux *subprog_aux(struct bpf_verifier_env *env, int subprog)
--- a/include/linux/hid_bpf.h
+++ b/include/linux/hid_bpf.h
@@ -196,6 +196,7 @@
 	struct list_head prog_list;
 	struct mutex prog_list_lock;	/* protects prog_list update */
 	struct srcu_struct srcu;	/* protects prog_list read-only access */
+	void *suse_kabi_padding;
 };
 
 #ifdef CONFIG_HID_BPF
