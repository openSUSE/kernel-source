 {
 	union hv_stats_object_identity identity = {
 		.vp.partition_id = partition_id,
@@ -973,7 +973,7 @@ static void mshv_vp_stats_unmap(u64 partition_id, u32 vp_index,
 }
 
 static int mshv_vp_stats_map(u64 partition_id, u32 vp_index,
