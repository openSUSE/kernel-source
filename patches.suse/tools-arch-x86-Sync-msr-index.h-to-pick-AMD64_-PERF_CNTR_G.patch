  [not in suse] bc6397cf0bc4f2b7 ("x86/cpu/topology: Define AMD64_CPUID_EXT_FEAT MSR")
  [not in suse] 84ecefb766748916 ("x86/resctrl: Add data structures and definitions for ABMC assignment")
  [not in suse] faebbc58cde9d8f6 ("x86/resctrl: Add support to enable/disable AMD ABMC feature")
  [not in suse] c4074ab87f3483de ("x86/apic: Enable Secure AVIC in the control MSR")
  [not in suse] 869e36b9660dd72a ("x86/apic: Allow NMI to be injected from hypervisor for Secure AVIC")
  [not in suse] 30c2b98aa84c76f2 ("x86/apic: Add new driver for Secure AVIC")
  [wrong in this header, in suse] 0c5caea762de31a8 ("perf/x86: Add PERF_CAP_PEBS_TIMING_INFO flag")
  68e61f6fd65610e7 ("KVM: SVM: Emulate PERF_CNTR_GLOBAL_STATUS_SET for PerfMonV2")
  [wrong] a3c4f3396b82849a ("x86/msr-index: Add AMD workload classification MSRs")
