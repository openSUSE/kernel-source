 tools/bpf/bpftool/link.c |   14 +++++++-------
 tools/bpf/bpftool/main.c |    8 ++++----
 tools/bpf/bpftool/map.c  |   10 +++++-----
 4 files changed, 22 insertions(+), 22 deletions(-)

