From: Sean Anderson <sean.anderson@linux.dev>
Date: Fri, 31 May 2024 12:13:35 -0400
Subject: PCI: xilinx-nwl: Clean up clock on probe failure/removal
Git-commit: cfd67903977b13f63340a4eb5a1cc890994f2c62
Patch-mainline: v6.12
References: git-fixes

Make sure we turn off the clock on probe failure and device removal.

[js] use .remove, not (non-present) .remove_new

Fixes: de0a01f52966 ("PCI: xilinx-nwl: Enable the clock through CCF")
Link: https://lore.kernel.org/r/20240531161337.864994-6-sean.anderson@linux.dev
Signed-off-by: Sean Anderson <sean.anderson@linux.dev>
Signed-off-by: Bjorn Helgaas <bhelgaas@google.com>
Signed-off-by: Jiri Slaby <jslaby@suse.cz>
---
 drivers/pci/host/pcie-xilinx-nwl.c |   17 +++++++++++++++--
 1 file changed, 15 insertions(+), 2 deletions(-)

--- a/drivers/pci/host/pcie-xilinx-nwl.c
+++ b/drivers/pci/host/pcie-xilinx-nwl.c
@@ -800,6 +800,7 @@ static int nwl_pcie_probe(struct platfor
 		return -ENODEV;
 
 	pcie = pci_host_bridge_priv(bridge);
+	platform_set_drvdata(pdev, pcie);
 
 	pcie->dev = dev;
 	pcie->ecam_value = NWL_ECAM_VALUE_DEFAULT;
@@ -823,14 +824,14 @@ static int nwl_pcie_probe(struct platfor
 	err = nwl_pcie_bridge_init(pcie);
 	if (err) {
 		dev_err(dev, "HW Initialization failed\n");
-		return err;
+		goto err_clk;
 	}
 
 	err = devm_of_pci_get_host_bridge_resources(dev, 0, 0xff, &res,
 						    &iobase);
 	if (err) {
 		dev_err(dev, "Getting bridge resources failed\n");
-		return err;
+		goto err_clk;
 	}
 
 	err = devm_request_pci_bus_resources(dev, &res);
@@ -873,9 +874,20 @@ static int nwl_pcie_probe(struct platfor
 
 error:
 	pci_free_resource_list(&res);
+err_clk:
+	clk_disable_unprepare(pcie->clk);
 	return err;
 }
 
+static int nwl_pcie_remove(struct platform_device *pdev)
+{
+	struct nwl_pcie *pcie = platform_get_drvdata(pdev);
+
+	clk_disable_unprepare(pcie->clk);
+
+	return 0;
+}
+
 static struct platform_driver nwl_pcie_driver = {
 	.driver = {
 		.name = "nwl-pcie",
@@ -883,5 +895,6 @@ static struct platform_driver nwl_pcie_d
 		.of_match_table = nwl_pcie_of_match,
 	},
 	.probe = nwl_pcie_probe,
+	.remove = nwl_pcie_remove,
 };
 builtin_platform_driver(nwl_pcie_driver);
