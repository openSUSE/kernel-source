@@ -7745,7 +7779,13 @@ int ath12k_wmi_wow_del_pattern(struct at
 	ath12k_dbg(ar->ab, ATH12K_DBG_WMI, "wmi tlv wow del pattern vdev_id %d pattern_id %d\n",
 		   vdev_id, pattern_id);
 
