 	RDT_OPT(RDT_FLAG_MBM_LOCAL, "mbmlocal", X86_FEATURE_CQM_MBM_LOCAL),
@@ -778,7 +778,7 @@ static int __init set_rdt_options(char *
 }
 __setup("rdt", set_rdt_options);
 
-bool __init rdt_cpu_has(int flag)
