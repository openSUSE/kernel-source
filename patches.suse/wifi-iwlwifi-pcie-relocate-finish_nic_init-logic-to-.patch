 .../intel/iwlwifi/pcie/gen1_2/internal.h      |  1 +
 .../intel/iwlwifi/pcie/gen1_2/trans.c         | 89 +++++++++++++++++++
 3 files changed, 92 insertions(+), 87 deletions(-)

