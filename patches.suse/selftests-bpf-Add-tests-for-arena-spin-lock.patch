---
 tools/testing/selftests/bpf/prog_tests/arena_spin_lock.c |  108 +++++++++++++++
 tools/testing/selftests/bpf/progs/arena_spin_lock.c      |   51 +++++++
 2 files changed, 159 insertions(+)
 create mode 100644 tools/testing/selftests/bpf/prog_tests/arena_spin_lock.c
