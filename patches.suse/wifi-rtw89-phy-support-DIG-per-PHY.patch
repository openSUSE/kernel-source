 drivers/net/wireless/realtek/rtw89/core.h |   2 +-
 drivers/net/wireless/realtek/rtw89/phy.c  | 226 +++++++++++++---------
 drivers/net/wireless/realtek/rtw89/phy.h  |   2 +-
