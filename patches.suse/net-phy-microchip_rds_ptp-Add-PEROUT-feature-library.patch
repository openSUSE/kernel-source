+++ b/drivers/net/phy/microchip_rds_ptp.c
@@ -54,6 +54,243 @@ static int mchp_rds_phy_set_bits_mmd(str
 	return phy_set_bits_mmd(phydev, PTP_MMD(clock), addr, val);
