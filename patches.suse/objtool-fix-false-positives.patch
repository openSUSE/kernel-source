From: Nikolay Borisov <nik.borisov@suse.com>
Date:   Thu Mar 12 14:29:23 2026 +0200
Subject: objtool: Fix false-positives
Patch-mainline: Never, our own fix
References: git-fixes

That -flive-patching compiler option introduces the following false positives in objtools:

    vmlinux.o: warning: objtool: hv_crash_nmi_local+0x40: crash_nmi_callback() is missing a __noreturn annotation
    vmlinux.o: warning: objtool: fred_sysvec_reboot+0x2d: __sysvec_reboot() is missing a __noreturn annotation
    vmlinux.o: warning: objtool: ghes_notify_nmi+0x268: __ghes_panic() is missing a __noreturn annotation
    vmlinux.o: warning: objtool: sysvec_reboot+0x38: __sysvec_reboot() is missing a __noreturn annotation

In order to keep the build objtool clean fix them by annotating __ghes_panic as __noreturn
and excluding the others from being checked for noreturn. This prevents objtool
warnings being treated as false positives.

Sign-off-by: Nikolay Borisov <nik.borisov@suse.com>
---
 drivers/acpi/apei/ghes.c |    2 +-
 tools/objtool/check.c    |   22 ++++++++++++++++++++++
 2 files changed, 23 insertions(+), 1 deletion(-)

--- a/drivers/acpi/apei/ghes.c
+++ b/drivers/acpi/apei/ghes.c
@@ -1019,7 +1019,7 @@ ghes_estatus_cache_add(struct acpi_hest_
 	}
 }
 
-static void __ghes_panic(struct ghes *ghes,
+__noreturn static void __ghes_panic(struct ghes *ghes,
 			 struct acpi_hest_generic_status *estatus,
 			 u64 buf_paddr, enum fixed_addresses fixmap_idx)
 {
--- a/tools/objtool/check.c
+++ b/tools/objtool/check.c
@@ -3962,6 +3962,26 @@ static bool is_ubsan_insn(struct instruc
 			"__ubsan_handle_builtin_unreachable"));
 }
 
+static bool should_ignore_livepatch_funcs(struct symbol *func) {
+
+      static const char *ignored_funcs[] = {
+              "hv_crash_nmi_local",
+              "fred_sysvec_reboot",
+              "sysvec_reboot",
+      };
+
+      if (!func)
+              return false;
+
+      for (int i = 0; i < ARRAY_SIZE(ignored_funcs); i++) {
+              if (!strcmp(func->name, ignored_funcs[i]))
+                      return true;
+      }
+
+      return false;
+}
+
+
 static bool ignore_unreachable_insn(struct objtool_file *file, struct instruction *insn)
 {
 	struct symbol *func = insn_func(insn);
@@ -3971,6 +3991,8 @@ static bool ignore_unreachable_insn(stru
 	if (insn->type == INSN_NOP || insn->type == INSN_TRAP || (func && func->ignore))
 		return true;
 
+	if (should_ignore_livepatch_funcs(func))
+		return true;
 	/*
 	 * Ignore alternative replacement instructions.  This can happen
 	 * when a whitelisted function uses one of the ALTERNATIVE macros.
