+++ b/arch/x86/events/intel/pt.c
@@ -1589,7 +1589,6 @@ void intel_pt_handle_vmx(int on)
 
 	local_irq_restore(flags);
 }
-EXPORT_SYMBOL_GPL(intel_pt_handle_vmx);
 
