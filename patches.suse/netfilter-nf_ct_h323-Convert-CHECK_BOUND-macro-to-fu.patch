 		if (!base || !(son->attr & DECODE)) {
 			PRINT("%*.s%s\n", (level + 1) * TAB_SIZE, " ",
 			      son->name);
@@ -623,19 +653,22 @@ static int decode_seqof(bitstr_t *bs, co
 	switch (f->sz) {
 	case BYTE:
 		BYTE_ALIGN(bs);
