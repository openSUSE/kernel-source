-static struct iwl_trans_pcie *iwl_pcie_get_trans_pcie(struct msix_entry *entry)
-{
-	u8 queue = entry->entry;
-	struct msix_entry *entries = entry - queue;
-
-	return container_of(entries, struct iwl_trans_pcie, msix_entries[0]);
-}
