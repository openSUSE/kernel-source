-		iwl_pcie_irq_handle_error(trans);
-	}
-
-	if (inta_hw & MSIX_HW_INT_CAUSES_REG_RESET_DONE)
-		iwl_trans_pcie_handle_reset_interrupt(trans);
-
-	if (!polling)
-		iwl_pcie_clear_irq(trans, entry->entry);
-
-	lock_map_release(&trans->sync_cmd_lockdep_map);
-
-	return IRQ_HANDLED;
-}
