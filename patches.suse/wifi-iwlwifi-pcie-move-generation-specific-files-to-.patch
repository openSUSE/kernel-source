-
-	inta_hw &= trans_pcie->hw_mask;
-
-	/* Alive notification via Rx interrupt will do the real work */
-	if (inta_hw & MSIX_HW_INT_CAUSES_REG_ALIVE) {
-		IWL_DEBUG_ISR(trans, "Alive interrupt\n");
