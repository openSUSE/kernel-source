 tools/testing/selftests/bpf/progs/mem_rdonly_untrusted.c      |  136 ++++++++++
 2 files changed, 145 insertions(+)
 create mode 100644 tools/testing/selftests/bpf/prog_tests/mem_rdonly_untrusted.c
