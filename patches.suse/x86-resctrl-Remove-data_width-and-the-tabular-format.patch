+
 static struct seq_buf last_cmd_status;
 static char last_cmd_status_buf[512];
 
@@ -2613,10 +2619,10 @@ static int schemata_list_add(struct rdt_
 
 	switch (r->schema_fmt) {
 	case RESCTRL_SCHEMA_BITMAP:
