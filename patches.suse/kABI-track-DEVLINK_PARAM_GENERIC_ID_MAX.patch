From: Thomas Bogendoerfer <tbogendoerfer@suse.de>
Subject: kABI: Track DEVLINK_PARAM_GENERIC_ID_MAX
Patch-mainline: Never, kABI specific
References: jsc#PED-14193 jsc#PED-14411 jsc#PED-15069

DEVLINK_PARAM_GENERIC_ID_MAX defines the border between generic
and driver specific devlink parameters, which makes it part of
the kABI. Therefore add it to the tracked enums and add placeholders,
which allows backporting of patches, which adds new devlink generic
parameteres after kABI freeze.

Signed-off-by: Thomas Bogendoerfer <tbogendoerfer@suse.de>
---
 include/net/devlink.h |    6 ++++++
 net/devlink/param.c   |   14 ++++++++++++--
 2 files changed, 18 insertions(+), 2 deletions(-)

--- a/include/net/devlink.h
+++ b/include/net/devlink.h
@@ -546,6 +546,12 @@ enum devlink_param_generic_id {
 	DEVLINK_PARAM_GENERIC_ID_NUM_DOORBELLS,
 	DEVLINK_PARAM_GENERIC_ID_MAX_MAC_PER_VF,
 
+	DEVLINK_PARAM_GENERIC_ID_SUSE_PLACEHOLDER_1,
+	DEVLINK_PARAM_GENERIC_ID_SUSE_PLACEHOLDER_2,
+	DEVLINK_PARAM_GENERIC_ID_SUSE_PLACEHOLDER_3,
+	DEVLINK_PARAM_GENERIC_ID_SUSE_PLACEHOLDER_4,
+	DEVLINK_PARAM_GENERIC_ID_SUSE_PLACEHOLDER_5,
+
 	/* add new param generic ids above here*/
 	__DEVLINK_PARAM_GENERIC_ID_MAX,
 	DEVLINK_PARAM_GENERIC_ID_MAX = __DEVLINK_PARAM_GENERIC_ID_MAX - 1,
--- a/net/devlink/param.c
+++ b/net/devlink/param.c
@@ -119,10 +119,20 @@ static const struct devlink_param devlin
 	},
 };
 
+/* SL-specific kABI tracking */
+#define EXPORT_ENUM_VALUE(name) \
+	char (*const __kabi_enum_##name)[name]; \
+	EXPORT_SYMBOL_GPL(__kabi_enum_##name)
+
+EXPORT_ENUM_VALUE(DEVLINK_PARAM_GENERIC_ID_MAX);
+
+#define INTERNAL_DEVLINK_PARAM_GENERIC_ID_MAX	\
+	(ARRAY_SIZE(devlink_param_generic) - 1)
+
 static int devlink_param_generic_verify(const struct devlink_param *param)
 {
 	/* verify it match generic parameter by id and name */
-	if (param->id > DEVLINK_PARAM_GENERIC_ID_MAX)
+	if (param->id > INTERNAL_DEVLINK_PARAM_GENERIC_ID_MAX)
 		return -EINVAL;
 	if (strcmp(param->name, devlink_param_generic[param->id].name))
 		return -ENOENT;
@@ -139,7 +149,7 @@ static int devlink_param_driver_verify(c
 	if (param->id <= DEVLINK_PARAM_GENERIC_ID_MAX)
 		return -EINVAL;
 	/* verify no such name in generic params */
-	for (i = 0; i <= DEVLINK_PARAM_GENERIC_ID_MAX; i++)
+	for (i = 0; i <= INTERNAL_DEVLINK_PARAM_GENERIC_ID_MAX; i++)
 		if (!strcmp(param->name, devlink_param_generic[i].name))
 			return -EEXIST;
 
