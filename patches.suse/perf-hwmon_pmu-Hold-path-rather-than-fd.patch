diff --git a/tools/perf/util/pmus.h b/tools/perf/util/pmus.h
index 33ecf765a92f..86842ee5f539 100644
--- a/tools/perf/util/pmus.h
+++ b/tools/perf/util/pmus.h
@@ -31,7 +31,7 @@ int perf_pmus__num_core_pmus(void);
