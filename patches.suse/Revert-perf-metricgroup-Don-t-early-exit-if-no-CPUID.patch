From: Jiri Slaby <jslaby@suse.cz>
Date: Mon, 9 Mar 2026 08:39:08 +0100
Subject: Revert "perf metricgroup: Don't early exit if no CPUID table exists"
References: bsc#1259358
Patch-mainline: not yet, under discussion <072e2a07-5c6f-47b5-9695-0a3ffe854ac8@kernel.org>

This reverts commit d4d30b1538bf1ea9f4030865f0fd671a02fec407 as it
breaks perf.

Signed-off-by: Jiri Slaby <jslaby@suse.cz>
---
 tools/perf/util/metricgroup.c |   18 +++++++++++++-----
 1 file changed, 13 insertions(+), 5 deletions(-)

--- a/tools/perf/util/metricgroup.c
+++ b/tools/perf/util/metricgroup.c
@@ -1563,6 +1563,8 @@ int metricgroup__parse_groups(struct evl
 {
 	const struct pmu_metrics_table *table = pmu_metrics_table__find();
 
+	if (!table)
+		return -EINVAL;
 	if (hardware_aware_grouping)
 		pr_debug("Use hardware aware grouping instead of traditional metric grouping method\n");
 
@@ -1600,16 +1602,22 @@ static int metricgroup__has_metric_or_gr
 
 bool metricgroup__has_metric_or_groups(const char *pmu, const char *metric_or_groups)
 {
-	const struct pmu_metrics_table *table = pmu_metrics_table__find();
+	const struct pmu_metrics_table *tables[2] = {
+		pmu_metrics_table__find(),
+		pmu_metrics_table__default(),
+	};
 	struct metricgroup__has_metric_data data = {
 		.pmu = pmu,
 		.metric_or_groups = metric_or_groups,
 	};
 
-	return pmu_metrics_table__for_each_metric(table,
-						  metricgroup__has_metric_or_groups_callback,
-						  &data)
-		? true : false;
+	for (size_t i = 0; i < ARRAY_SIZE(tables); i++) {
+		if (pmu_metrics_table__for_each_metric(tables[i],
+							metricgroup__has_metric_or_groups_callback,
+							&data))
+			return true;
+	}
+	return false;
 }
 
 static int metricgroup__topdown_max_level_callback(const struct pmu_metric *pm,
