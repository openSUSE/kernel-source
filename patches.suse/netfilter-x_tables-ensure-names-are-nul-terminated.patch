From: Florian Westphal <fw@strlen.de>
Date: Tue, 31 Mar 2026 23:13:36 +0200
Subject: netfilter: x_tables: ensure names are nul-terminated
Git-commit: a958a4f90ddd7de0800b33ca9d7b886b7d40f74e
Patch-mainline: v6.18 or v6.18-rc8 (next release)
References: CVE-2026-43028 bsc#1263934

Reject names that lack a \0 character before feeding them
to functions that expect c-strings.

Fixes tag is the most recent commit that needs this change.

Fixes: c38c4597e4bf ("netfilter: implement xt_cgroup cgroup2 path match")
Signed-off-by: Florian Westphal <fw@strlen.de>
Signed-off-by: Pablo Neira Ayuso <pablo@netfilter.org>
Acked-by: Fernando Fernandez Mancera <fmancera@suse.de>
---
 net/netfilter/xt_cgroup.c  |    3 +++
 net/netfilter/xt_rateest.c |    5 +++++
 2 files changed, 8 insertions(+)

--- a/net/netfilter/xt_cgroup.c
+++ b/net/netfilter/xt_cgroup.c
@@ -54,6 +54,9 @@ static int cgroup_mt_check_v1(const stru
 
 	info->priv = NULL;
 	if (info->has_path) {
+		if (strnlen(info->path, sizeof(info->path)) >= sizeof(info->path))
+			return -ENAMETOOLONG;
+
 		cgrp = cgroup_get_from_path(info->path);
 		if (IS_ERR(cgrp)) {
 			pr_info("xt_cgroup: invalid path, errno=%ld\n",
--- a/net/netfilter/xt_rateest.c
+++ b/net/netfilter/xt_rateest.c
@@ -94,6 +94,11 @@ static int xt_rateest_mt_checkentry(cons
 		goto err1;
 	}
 
+	if (strnlen(info->name1, sizeof(info->name1)) >= sizeof(info->name1))
+		return -ENAMETOOLONG;
+	if (strnlen(info->name2, sizeof(info->name2)) >= sizeof(info->name2))
+		return -ENAMETOOLONG;
+
 	ret  = -ENOENT;
 	est1 = xt_rateest_lookup(info->name1);
 	if (!est1)
