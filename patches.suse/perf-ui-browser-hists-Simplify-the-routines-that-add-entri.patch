 	return 1;
 }
@@ -3324,27 +3314,23 @@ static int evsel__hists_browse(struct evsel *evsel, int nr_events, const char *h
 			if (bi == NULL)
 				goto skip_annotation;
 
-			nr_options += add_annotate_opt(browser,
-						       &actions[nr_options],
