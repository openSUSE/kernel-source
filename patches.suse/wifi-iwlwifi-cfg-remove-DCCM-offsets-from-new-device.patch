 drivers/net/wireless/intel/iwlwifi/cfg/ax210.c | 8 --------
 drivers/net/wireless/intel/iwlwifi/cfg/bz.c    | 8 --------
 drivers/net/wireless/intel/iwlwifi/cfg/dr.c    | 8 --------
 drivers/net/wireless/intel/iwlwifi/cfg/sc.c    | 8 --------
