 arch/x86/kernel/cpu/resctrl/core.c |    6 ++++--
 fs/resctrl/ctrlmondata.c           |   13 +++++++++----
 fs/resctrl/internal.h              |    4 ++--
 fs/resctrl/monitor.c               |    6 ++++--
 fs/resctrl/rdtgroup.c              |    6 +++---
