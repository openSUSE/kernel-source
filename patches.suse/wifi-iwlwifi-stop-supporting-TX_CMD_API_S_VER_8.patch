From 579724de9ee349b5a110fa9e9f65b53fb6bf834e Mon Sep 17 00:00:00 2001
From: Miri Korenblit <miriam.rachel.korenblit@intel.com>
Date: Sun, 27 Apr 2025 22:22:45 +0300
Subject: [PATCH] wifi: iwlwifi: stop supporting TX_CMD_API_S_VER_8
Git-commit: 579724de9ee349b5a110fa9e9f65b53fb6bf834e
Patch-mainline: v6.16-rc1
References: jsc#PED-14425

This version is not used on any device. Don't support it.

Signed-off-by: Miri Korenblit <miriam.rachel.korenblit@intel.com>
Acked-by: Takashi Iwai <tiwai@suse.de>

---
 drivers/net/wireless/intel/iwlwifi/fw/api/tx.h | 3 +--
 1 file changed, 1 insertion(+), 2 deletions(-)

diff --git a/drivers/net/wireless/intel/iwlwifi/fw/api/tx.h b/drivers/net/wireless/intel/iwlwifi/fw/api/tx.h
index 0b59fabde7f0..67355ac243c5 100644
--- a/drivers/net/wireless/intel/iwlwifi/fw/api/tx.h
+++ b/drivers/net/wireless/intel/iwlwifi/fw/api/tx.h
@@ -298,8 +298,7 @@ struct iwl_tx_cmd_gen3 {
 	__le32 rate_n_flags;
 	u8 reserved[8];
 	struct ieee80211_hdr hdr[];
-} __packed; /* TX_CMD_API_S_VER_8,
-	     * TX_CMD_API_S_VER_10,
+} __packed; /* TX_CMD_API_S_VER_10,
 	     * TX_CMD_API_S_VER_11
 	     */
 
