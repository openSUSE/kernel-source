From 6d3789d347a7af5c4b0b2da3af47b8d9da607ab2 Mon Sep 17 00:00:00 2001
From: Christian Brauner <brauner@kernel.org>
Date: Sun, 23 Nov 2025 17:33:51 +0100
Subject: [PATCH] Fixes a UAF for src_info

References: jsc#PED-14170 git-fixes
Patch-mainline: v6.19-rc1
Git-commit: 6d3789d347a7af5c4b0b2da3af47b8d9da607ab2 (partial)

Fixes a UAF for src_info as well.

Link: https://patch.msgid.link/20251123-work-fd-prepare-v4-33-b6efa1706cfd@kernel.org
Signed-off-by: Christian Brauner <brauner@kernel.org>
Acked-by: Michal Suchanek <msuchanek@suse.de>
---
 arch/powerpc/platforms/pseries/papr-hvpipe.c | 6 ++----
 1 file changed, 2 insertions(+), 4 deletions(-)

diff --git a/arch/powerpc/platforms/pseries/papr-hvpipe.c b/arch/powerpc/platforms/pseries/papr-hvpipe.c
index 431f6a3da4c5a..2c297dec3c644 100644
--- a/arch/powerpc/platforms/pseries/papr-hvpipe.c
+++ b/arch/powerpc/platforms/pseries/papr-hvpipe.c
@@ -484,7 +484,7 @@ static const struct file_operations papr_hvpipe_handle_ops = {
 
 static int papr_hvpipe_dev_create_handle(u32 srcID)
 {
-	struct hvpipe_source_info *src_info;
+	struct hvpipe_source_info *src_info __free(kfree) = NULL;
 	struct file *file;
 	long err;
 	int fd;
@@ -525,6 +525,7 @@ static int papr_hvpipe_dev_create_handle(u32 srcID)
 		goto free_fd;
 	}
 
+	retain_and_null_ptr(src_info);
 	spin_lock(&hvpipe_src_list_lock);
 	/*
 	 * If two processes are executing ioctl() for the same
@@ -546,9 +547,6 @@ static int papr_hvpipe_dev_create_handle(u32 srcID)
 	fput(file);
 free_fd:
 	put_unused_fd(fd);
-free_buf:
-	kfree(src_info);
-	return err;
 }
 
