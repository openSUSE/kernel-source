@@ -581,7 +581,7 @@ static int linker_load_obj_file(struct b
 	obj_byteorder = ehdr->e_ident[EI_DATA];
 	if (obj_byteorder != ELFDATA2LSB && obj_byteorder != ELFDATA2MSB) {
