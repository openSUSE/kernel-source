 tools/testing/selftests/bpf/prog_tests/test_veristat.c |    5 
 tools/testing/selftests/bpf/progs/prepare.c            |    1 
 tools/testing/selftests/bpf/progs/set_global_vars.c    |   41 ++++++
 tools/testing/selftests/bpf/veristat.c                 |  101 +++++++++++++++--
