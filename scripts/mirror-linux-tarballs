#!/bin/bash -e

DEST_Default=/mounts/mirror/kernel
DEST=$DEST_Default
kerncvs_user=
until [ "$#" = "0" ] ; do
	case "$1" in
		--user=*)
			kerncvs_user=${1#*=}
			shift
			;;
		-u|--user)
			kerncvs_user=$2
			shift 2
			;;
		--dest=*)
			DEST=${1#*=}
			shift
			;;
		-d|--dest)
			DEST=$2
			shift 2
			;;
		-h|--help|-v|--version)
			cat <<EOF

${0##*/} downloads upstream kernel tarballs for tar-up

these options are recognized:
    -u username to use when downnloading from kerncvs
    -d destination directory (default $DEST_Default)
       When different destination directory is specified it needs to be set
       as LINUX_TAR_DIR environment variable when runninng tar-up

EOF
			exit 1
			;;
		*)
			echo "unknown option '$1'" >&2
			exit 1
			;;
	esac
done


SRC=rsync.kernel.org::pub/linux/kernel
if host kerncvs.suse.de >& /dev/null ; then
	SRC=kerncvs.suse.de:/mounts/mirror/kernel
	if [ -n "$kerncvs_user" ] ; then
		SRC=$kerncvs_user@$SRC
	fi
fi

mkdir -p "$DEST"

# v2.6 - Linus' final releases only
for v in v2.6; do
	rsync -aq \
		--exclude='*.tar.gz*' --exclude='patch-*' \
		--exclude='ChangeLog*' --exclude='LATEST-IS-*' \
		--exclude='linux-*.*.*.*.tar.*' --exclude=longterm \
		--exclude=longterm-review --exclude=pre-releases \
		--exclude=incr --exclude=next --exclude=stable-review \
		--exclude=testing --exclude=snapshots \
		"$SRC/$v" "$DEST"
	done

# v3.0 and later - also include -rc releases
versions=($(rsync "$SRC/" | sed -rn 's/^[dl]r.x.* (v[3-9]\.[^ ]*|v[1-9][0-9][^ ]*)$/\1/p'))
for v in "${versions[@]}"; do
	rsync -aq \
		--exclude='*.tar.gz*' --exclude='patch-*' \
		--exclude='ChangeLog*' --exclude='LATEST-IS-*' \
		--exclude='linux-*.*.*.tar.*' --exclude=longterm \
		--exclude=incr --exclude=next --exclude=stable-review \
		"$SRC/$v" "$DEST"
	done
