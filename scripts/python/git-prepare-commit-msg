#
# This hook annotates merge commit messages with information about files
# that were automatically resolved using custom merge drivers.

import os
import sys
import subprocess

from kutil import pygit2_wrapper as pygit2

if len(sys.argv) < 2 or sys.argv[1] == "-h":
    print("Are you ouf of mind? This shall be invoked as a git-hook", file=sys.stderr)
    sys.exit(1)

commit_file = sys.argv[1]
commit_source = sys.argv[2] if len(sys.argv) > 2 else None
sha1 = sys.argv[3] if len(sys.argv) > 3 else None

# Only process merge commits
source_repo = pygit2.Repository('.')
merge_head = os.path.join(source_repo.path, "MERGE_HEAD")
if not os.path.exists(merge_head):
    sys.exit(0)

# Skip if commit message already came from a template or message flag
# (we only want to enhance auto-generated merge messages)
if commit_source in ("message", "template", "squash", "commit"):
    sys.exit(0)

# Check if we have a merge driver log
log_file = os.path.join(source_repo.path, "MERGE_DRIVER_LOG")
if not os.path.exists(log_file):
    sys.exit(0)

# Read the log and collect file:driver pairs
file_driver_pairs = []
with open(log_file, "r") as f:
    for line in f:
        line = line.strip()
        if not line:
            continue
        parts = line.split(":", 1)
        if len(parts) == 2:
            driver, filepath = parts
            if driver and filepath:
                file_driver_pairs.append((filepath, driver))

# Clean up the log file
os.remove(log_file)

# If no drivers were used, exit
if not file_driver_pairs:
    sys.exit(0)

# Append merge driver information to commit message
with open(commit_file, "a") as f:
    f.write("\n")
    f.write("Merge resolved automatically by custom merge drivers:\n")
    for filepath, driver in file_driver_pairs:
        f.write(f"  - {filepath}: {driver}\n")

sys.exit(0)
