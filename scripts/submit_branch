#!/bin/bash
SUBMIT_BRANCH="SUSE:SLE-11-SP4:Update"
HOME_BRANCH="home:$USER:branches:$SUBMIT_BRANCH"

#set -x
BS_URL=https://api.suse.de
#OSC_OPTS="-H" # For debugging
HOME_BRANCH_DIR="$HOME_BRANCH"
OSC_KERNEL_DIR="$HOME_BRANCH/kernel-source"

# Delete the previous BS branch because it got disconnected from the original repository
# after the submit request got accepted - Sigh...
osc $OSC_OPTS -A $BS_URL rdelete -m "Dropping last submission" -r $HOME_BRANCH 
osc $OSC_OPTS -A $BS_URL branch "$SUBMIT_BRANCH" kernel-source || exit 1
[ -d "$HOME_BRANCH_DIR" ] && rm -rf "$HOME_BRANCH_DIR"
osc $OSC_OPTS -A $BS_URL co $HOME_BRANCH/kernel-source 
./scripts/tar-up.sh -d $OSC_KERNEL_DIR || exit 1

tmpdir=$(mktemp -d /tmp/${0##*/}.XXXXXX)
trap 'rm -rf "$tmpdir"' EXIT
HEAD_SHA="$(git show -s --pretty='format:%h')"
(
	cd $OSC_KERNEL_DIR || exit 1
	osc addremove || exit 1
	osc ci || exit 1
	osc mr -m "Regular submission" | tail -n1 > $tmpdir/mr || exit 1
)

echo "Submitted head $HEAD_SHA mr $(cat $tmpdir/mr)"

