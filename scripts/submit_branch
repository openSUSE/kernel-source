#!/bin/bash
# Usage: ./scripts/submit_branch <LU-number>
# With <LU-number> as specified for this submission (e.g. 15)

[ $# -ne 1 ] && {
	echo "Please specify liveupdate number"
	exit 1
}

BS_URL="https://api.suse.de"
LU_NUMBER=$1
LU_MODULE="SLE-Module-Live-Patching_15-SP7"
LU_PACKAGE="kernel-livepatch-SLE15-SP7_Update_${LU_NUMBER}"
LU_ARCHS="x86_64 ppc64le s390x"
SUBMIT_BRANCH="SUSE:SLE-15-SP7:Update"
DEVEL_BRANCH="Devel:Kernel:SLE15-SP7:Submit"
HEAD_SHA="$(git show -s --pretty='format:%h')"

for arch in ${LU_ARCHS}
do
	LU_MODULES="${LU_MODULES} ${LU_MODULE}_${arch}"
done

scripts/tar-up || exit $?

osc -A ${BS_URL} rdelete -f -r -m. ${DEVEL_BRANCH}
scripts/osc_wrapper upload --ibs ${DEVEL_BRANCH}
osc -A ${BS_URL} linkpac					\
	Devel:kGraft:patches:SLE15-SP7_Update_${LU_NUMBER}	\
	${LU_PACKAGE}						\
	${DEVEL_BRANCH}

tmpdir=$(mktemp -d /tmp/${0##*/}.XXXXXX)
trap 'rm -rf "$tmpdir"' EXIT

cd ${tmpdir}

for mod in ${LU_MODULES}
do
	osc -A ${BS_URL} bco SUSE:Channels ${mod} ${DEVEL_BRANCH}
done

cd ${DEVEL_BRANCH}

for dir in *
do
	cd ${dir}
	awk 'BEGIN {
		upd = '${LU_NUMBER}';
		updstr = sprintf("Update_%d", upd);
		package = "'${LU_PACKAGE}'";
		l = 1;
		last = 0;
	}
	{
		lin[l] = $0;
		u = index($0, "Update_");
		if (u > 0) {
			if (index($0, updstr) > 0)
				last = -1;
			else if (last >= 0)
				last = l;
		}
		l++;
	}
	END {
		for (i = 1; i <= l; i++) {
			printf("%s\n", lin[i]);
			if (i == last) {
				printf("    <binary name=\"kernel-livepatch-6_4_0-FIXME-default\" package=\"%s\" supportstatus=\"l3\"/>\n", package);
				printf("    <binary name=\"kernel-livepatch-6_4_0-FIXME-default-debuginfo\" package=\"%s\"/>\n", package);
				printf("    <binary name=\"%s-debugsource\" package=\"%s\"/>\n", package, package);
			}
		}
	}' _channel > _channel.new
	echo $dir
	mv _channel.new _channel
	osc ci -m `date +%m/%Y`
	cd ..
done

echo "After successful build (see:"
echo "  https://build.suse.de/project/monitor?project=Devel%3AKernel%3ASLE15-SP7%3ASubmit"
echo "), please issue:"
echo "osc -A ${BS_URL} mr ${DEVEL_BRANCH} kernel-source ${LU_PACKAGE} ${LU_MODULES} ${SUBMIT_BRANCH}"

echo "Submission head ${HEAD_SHA}"

