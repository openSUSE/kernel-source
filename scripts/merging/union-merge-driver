#
# Wrapper around git's built-in union merge driver that logs merge activity
# for use by prepare-commit-msg hook.
#
# Usage: union-merge-driver %A %O %B %P
#   %A = local version
#   %O = base's version
#   %B = remote branch's version
#   %P = merged (optional, for logging)

local="$1"
base="$2"
remote="$3"
merged="$4"

# Perform the union merge using git's built-in merge-file with union strategy
git merge-file --union "$local" "$base" "$remote"
result=$?

# Log the merge driver invocation if this appears to be during a merge
if [ -n "$merged" ]; then
    git_dir=$(git rev-parse --git-dir 2>/dev/null)
    if [ -n "$git_dir" ] && [ -f "$git_dir/MERGE_HEAD" ]; then
        echo "union-merge-driver:$merged" >> "$git_dir/MERGE_DRIVER_LOG" 2>/dev/null || true
    fi
fi

exit $result
