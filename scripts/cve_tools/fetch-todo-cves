#!/usr/bin/env bash
# fetch-todo-cves — Fetch CVE related c-k-f output files from our remote worker.
#
# Requires rank_order_cves.py deployed on the source host.

set -eu

SRC_HOST="kss.prg2.suse.org"
SRC_USER="sles"
SCANNER_PATH="/home/$SRC_USER/scripts/rank_order_cves.py"

MODE=""            # "local" or "ls"
LOCAL_DIR=""
FILE_COUNT=10
REVERSE_FLAG=""
AI_RANK_FLAG=""

CVE_ARGS=()
EMAIL_ARGS=()
SUBSYSTEM_ARGS=()

SSH_COMMON="-o StrictHostKeyChecking=accept-new -o ConnectTimeout=30"

src_ssh() { ssh $SSH_COMMON "${SRC_USER}@${SRC_HOST}" "$@"; }
src_scp() { scp $SSH_COMMON "$@"; }

die() { echo "ERROR: $*" >&2; exit 1; }

show_help() {
    cat << EOF

$(basename "$0") — Fetch CVE c-k-f files from a remote server.

Usage:
  $(basename "$0") [-n COUNT] -d <dir> [options]
  $(basename "$0") [-n COUNT] --ls [options]

Modes:
  -d, --dest <dir>    Download files to a local directory (isolate mode)
  --ls                List matching files on source (dry run)

Ranking Options:
  -n <num>            Number of files to fetch (default: 10)
  --reverse           Sort lowest priority first (delegate the boring ones)
  --ai-rank           Rank purely by AI security review scores

Filters:
  -c, --cve           Only process specific CVE IDs (e.g. CVE-2024-1234)
  -e, --email         Filter by maintainer email (e.g. your-email@suse.com)
  -s, --subsystem     Filter by subsystem (case-insensitive substring match).
                      Supports aliases: "mm": "MEMORY MANAGEMENT"
                                        "fs": "FILESYSTEMS"
    
    Email and subsystem matching is derived from suse-get-maintainers.

Other:
  -h, --help          Show this message

Examples:
  # Fetch a batch of the top 20 high-priority CVE files
  $(basename "$0") -n 20 -d ./cves

  # Fetch specific CVEs by ID
  $(basename "$0") -d ./out -c CVE-2024-1234 CVE-2024-5678

  # Fetch CVEs for subsystems you maintain
  $(basename "$0") -d ./out -e your-email@suse.com

  # Fetch CVEs for a subsystem (using an alias)
  $(basename "$0") -d ./mm-cves -s "MEMORY MANAGEMENT"

  # List the top 10 highest-priority CVEs (default ranking)
  $(basename "$0") --ls

  # List the top 20 highest-priority CVEs (AI ranking)
  $(basename "$0") -n 20 --ls --ai-rank

  # List CVEs for a subsystem
  $(basename "$0") --ls -s "UFS DRIVERS"

EOF
    exit 0
}

while [[ $# -gt 0 ]]; do
    case $1 in
        -h|--help)      show_help ;;
        --ls)           MODE="ls"; shift ;;
        -d|--dest)      MODE="local"; LOCAL_DIR="$2"; shift 2 ;;
        -n)             FILE_COUNT="$2"; shift 2 ;;
        --reverse)      REVERSE_FLAG="--reverse"; shift ;;
        --ai-rank)      AI_RANK_FLAG="--ai-rank"; shift ;;
        -c|--cve)
            shift
            while [[ $# -gt 0 && "$1" != -* ]]; do
                CVE_ARGS+=("$1")
                shift
            done
            ;;
        -e|--email)
            shift
            while [[ $# -gt 0 && "$1" != -* ]]; do
                EMAIL_ARGS+=("$1")
                shift
            done
            ;;
        -s|--subsystem)
            shift
            while [[ $# -gt 0 && "$1" != -* ]]; do
                SUBSYSTEM_ARGS+=("$1")
                shift
            done
            ;;
        *)
            echo "Unknown option: $1" >&2
            echo "Run '$(basename "$0") --help' for usage." >&2
            exit 1 ;;
    esac
done

[[ -n "$MODE" ]] || die "You must specify a mode: -d/--dest <dir> or --ls."

if [[ "$MODE" == "local" ]]; then
    [[ -n "$LOCAL_DIR" ]] || die "-d/--dest requires a directory argument."
    [[ -d "$LOCAL_DIR" ]] || die "Local directory does not exist: $LOCAL_DIR"
fi

# Build filter args as an array so multi-word values stay intact
FILTER_ARGS=()
if [[ ${#CVE_ARGS[@]} -gt 0 ]]; then
    FILTER_ARGS+=( -c "${CVE_ARGS[@]}" )
fi
if [[ ${#EMAIL_ARGS[@]} -gt 0 ]]; then
    FILTER_ARGS+=( -e "${EMAIL_ARGS[@]}" )
fi
if [[ ${#SUBSYSTEM_ARGS[@]} -gt 0 ]]; then
    FILTER_ARGS+=( -s "${SUBSYSTEM_ARGS[@]}" )
fi

# Assemble the remote argv and escape it so the REMOTE shell re-parses it correctly
build_remote_cmd() {
    local mode_flag="$1"          # --ls or --isolate
    local -a argv=( python3 "$SCANNER_PATH" -n "$FILE_COUNT" "$mode_flag" )
    if [[ -n "$REVERSE_FLAG" ]]; then argv+=( "$REVERSE_FLAG" ); fi
    if [[ -n "$AI_RANK_FLAG" ]]; then argv+=( "$AI_RANK_FLAG" ); fi
    if [[ ${#FILTER_ARGS[@]} -gt 0 ]]; then argv+=( "${FILTER_ARGS[@]}" ); fi
    printf '%q ' "${argv[@]}"
}

if [[ "$MODE" == "ls" ]]; then
    src_ssh "$(build_remote_cmd --ls)"
    exit 0
fi

# ──────────────────────────────────────────────
# Transfer
# ──────────────────────────────────────────────
# 1. Isolate files on source to prevent races
echo "Scanning and isolating top ${FILE_COUNT} files on ${SRC_HOST}..."
REMOTE_OUTPUT=$(src_ssh "$(build_remote_cmd --isolate)")

ISOLATED_DIR=$(echo "$REMOTE_OUTPUT" | grep "^ISOLATED_DIR:" | cut -d':' -f2-)
[[ -n "$ISOLATED_DIR" ]] || die "Failed to get processing directory from source."

mapfile -t FILES < <(echo "$REMOTE_OUTPUT" | grep -v "^ISOLATED_DIR:" | grep -v "^SRC_DIR:")

if [[ ${#FILES[@]} -eq 0 ]]; then
    echo "No files matched the criteria."
    exit 0
fi

echo "Isolated ${#FILES[@]} file(s) in ${ISOLATED_DIR} on ${SRC_HOST}."

# 2. Download directly into the destination directory
echo "Downloading from ${SRC_HOST} to ${LOCAL_DIR}..."
if ! src_scp "${SRC_USER}@${SRC_HOST}:${ISOLATED_DIR}/*" "${LOCAL_DIR}/"; then
    echo "Download failed. Files remain isolated on source at: ${ISOLATED_DIR}" >&2
    exit 1
fi

echo "Copied ${#FILES[@]} file(s) to ${LOCAL_DIR}."

# 3. Summary — isolated dir is preserved on source
echo ""
echo "Isolated files preserved on ${SRC_HOST} at: ${ISOLATED_DIR}"
echo "Done. ${#FILES[@]} file(s) transferred: ${SRC_HOST} -> ${LOCAL_DIR}"
