From: "Ivan T. Ivanov" <iivanov@suse.de>
Date: Thu, 23 Apr 2026 11:58:18 +0300
Subject: kabi: arm: io: Export ioremap_prot() symbol
Patch-mainline: Never, kABI workaround
References: CVE-2026-23346 bsc#1260529

Upstream commit [1] renamed the symbol, but with upstream commit [2]
symbol is back, so export it again to keep status quo.

ioremap_prot() was unaligned to preserve the kABI properties.

[1] f6bf47ab32e0 ("arm64: io: Rename ioremap_prot() to __ioremap_prot()")
[2] 8f098037139b ("arm64: io: Extract user memory type in ioremap_prot()")

Signed-off-by: Ivan T. Ivanov <iivanov@suse.de>
Reviewed-by: Takashi Iwai <tiwai@suse.de>
---
 arch/arm64/include/asm/io.h |   14 +-------------
 arch/arm64/mm/ioremap.c     |   15 +++++++++++++++
 2 files changed, 16 insertions(+), 13 deletions(-)

--- a/arch/arm64/include/asm/io.h
+++ b/arch/arm64/include/asm/io.h
@@ -268,20 +268,8 @@ __iowrite64_copy_inlined(void __iomem *t
  */
 
  void __iomem *__ioremap_prot(phys_addr_t phys, size_t size, unsigned long prot);
+void __iomem *ioremap_prot(phys_addr_t phys, size_t size, unsigned long user_prot);
 
-static inline void __iomem *ioremap_prot(phys_addr_t phys, size_t size,
-					 unsigned long user_prot)
-{
-	pgprot_t prot;
-	pteval_t user_prot_val = pgprot_val(__pgprot(user_prot));
-
-	if (WARN_ON_ONCE(!(user_prot_val & PTE_USER)))
-		return NULL;
-
-	prot = __pgprot_modify(PAGE_KERNEL, PTE_ATTRINDX_MASK,
-			       user_prot_val & PTE_ATTRINDX_MASK);
-	return __ioremap_prot(phys, size, pgprot_val(prot));
-}
 #define ioremap_prot ioremap_prot
 
 #define ioremap(addr, size)	\
--- a/arch/arm64/mm/ioremap.c
+++ b/arch/arm64/mm/ioremap.c
@@ -20,6 +20,21 @@ void __iomem *__ioremap_prot(phys_addr_t
 }
 EXPORT_SYMBOL(__ioremap_prot);
 
+void __iomem *ioremap_prot(phys_addr_t phys, size_t size,
+			   unsigned long user_prot)
+{
+	pgprot_t prot;
+	pteval_t user_prot_val = pgprot_val(__pgprot(user_prot));
+
+	if (WARN_ON_ONCE(!(user_prot_val & PTE_USER)))
+		return NULL;
+
+	prot = __pgprot_modify(PAGE_KERNEL, PTE_ATTRINDX_MASK,
+			       user_prot_val & PTE_ATTRINDX_MASK);
+	return __ioremap_prot(phys, size, pgprot_val(prot));
+}
+EXPORT_SYMBOL(ioremap_prot);
+
 /*
  * Must be called after early_fixmap_init
  */
