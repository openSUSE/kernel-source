From: Michal Kubecek <mkubecek@suse.cz>
Date: Thu, 28 May 2026 21:39:59 +0200
Subject: kabi: hide work_disabled flag in struct xfrm_policy_hthresh
Patch-mainline: Never, kabi workaround
References: CVE-2026-31516 bsc#1262755

To backport mainline commit 29fe3a61bcdc ("xfrm: prevent
policy_hthresh.work from racing with netns teardown") into kernels without
delayed_work_sync(), we add a bool member work_disabled to struct
xfrm_policy_htresh which is kabi protected.

Thankfully this flag fits into the 4-byte padding at the end of the
structure so that all we need is to hide it from genksyms. A static assert
is added to make sure the size of the structure is preserved.

Signed-off-by: Michal Kubecek <mkubecek@suse.cz>
Reviewed-by: Petr Pavlu <petr.pavlu@suse.com>
---
 include/net/netns/xfrm.h | 13 +++++++++++++
 1 file changed, 13 insertions(+)

--- a/include/net/netns/xfrm.h
+++ b/include/net/netns/xfrm.h
@@ -19,6 +19,15 @@ struct xfrm_policy_hash {
 	u8			sbits6;
 };
 
+struct __orig_xfrm_policy_hthresh {
+	struct work_struct	work;
+	seqlock_t		lock;
+	u8			lbits4;
+	u8			rbits4;
+	u8			lbits6;
+	u8			rbits6;
+};
+
 struct xfrm_policy_hthresh {
 	struct work_struct	work;
 	seqlock_t		lock;
@@ -26,8 +35,12 @@ struct xfrm_policy_hthresh {
 	u8			rbits4;
 	u8			lbits6;
 	u8			rbits6;
+#ifndef __GENKSYMS__
 	bool			work_disabled;
+#endif
 };
+suse_kabi_static_assert(sizeof(struct xfrm_policy_hthresh) ==
+			sizeof(struct __orig_xfrm_policy_hthresh));
 
 struct netns_xfrm {
 	struct list_head	state_all;
