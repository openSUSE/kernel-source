From b58f8705ebb1d7bc754910b8f46ff4490a06e5e4 Mon Sep 17 00:00:00 2001
From: Michal Suchanek <msuchanek@suse.de>
Date: Tue, 6 Aug 2024 10:19:06 +0200
Subject: [PATCH] kABI: do not rename tpm_do_selftest, tpm_pcr_read_dev, and
 tpm1_getcap

References: bsc#1082555
---
 drivers/char/tpm/tpm.h | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/drivers/char/tpm/tpm.h b/drivers/char/tpm/tpm.h
--- a/drivers/char/tpm/tpm.h
+++ b/drivers/char/tpm/tpm.h
@@ -537,12 +537,15 @@ ssize_t tpm_transmit_cmd(struct tpm_chip *chip, struct tpm_space *space,
 
 int tpm1_pm_suspend(struct tpm_chip *chip, int tpm_suspend_pcr);
 int tpm1_auto_startup(struct tpm_chip *chip);
+#define tpm1_do_selftest tpm_do_selftest
 int tpm1_do_selftest(struct tpm_chip *chip);
 int tpm1_get_timeouts(struct tpm_chip *chip);
 unsigned long tpm1_calc_ordinal_duration(struct tpm_chip *chip, u32 ordinal);
 int tpm1_pcr_extend(struct tpm_chip *chip, int pcr_idx, const u8 *hash,
 		    const char *log_msg);
+#define tpm1_pcr_read tpm_pcr_read_dev
 int tpm1_pcr_read(struct tpm_chip *chip, int pcr_idx, u8 *res_buf);
+#define tpm1_getcap tpm_getcap
 ssize_t tpm1_getcap(struct tpm_chip *chip, u32 subcap_id, cap_t *cap,
 		    const char *desc, size_t min_cap_length);
 int tpm1_get_random(struct tpm_chip *chip, u8 *out, size_t max);
-- 
