From b684173719f1ee6c7f4212e3b8e00cec24cbaff2 Mon Sep 17 00:00:00 2001
From: Fabiano Rosas <farosas@suse.de>
Date: Thu, 28 May 2026 10:23:17 -0300
Subject: [PATCH] kABI fix for x86/fpu: Allow caller to constrain xfeatures
 when copying
Patch-mainline: Never, kABI workaround
References: bsc#1247954

Commit 18164f66e6c5 ("x86/fpu: Allow caller to constrain xfeatures
when copying to uabi buffer") has added an 'xfeatures' argument to
fpu_copy_guest_fpstate_to_uabi.

Keep kabi stable by making the old function a wrapper for the new
one. Pass ~0 in xfeatures to keep the previous behavior of masking all
user features in __copy_xstate_to_uabi_buf:

    case XSTATE_COPY_XSAVE:
        header.xfeatures &= fpstate->user_xfeatures & xfeatures;

Reviewed-by: Jan Kara <jack@suse.cz>
Signed-off-by: Fabiano Rosas <farosas@suse.de>
---
 arch/x86/include/asm/fpu/api.h |    5 ++++-
 arch/x86/kernel/fpu/core.c     |   12 ++++++++++--
 arch/x86/kvm/x86.c             |    6 +++---
 3 files changed, 17 insertions(+), 6 deletions(-)

--- a/arch/x86/include/asm/fpu/api.h
+++ b/arch/x86/include/asm/fpu/api.h
@@ -144,7 +144,10 @@ extern void fpu_free_guest_fpstate(struc
 extern int fpu_swap_kvm_fpstate(struct fpu_guest *gfpu, bool enter_guest);
 
 extern void fpu_copy_guest_fpstate_to_uabi(struct fpu_guest *gfpu, void *buf,
-					   unsigned int size, u64 xfeatures, u32 pkru);
+					   unsigned int size, u32 pkru);
+extern void fpu_copy_guest_fpstate_to_uabi_new(struct fpu_guest *gfpu, void *buf,
+					       unsigned int size, u64 xfeatures,
+					       u32 pkru);
 extern int fpu_copy_uabi_to_guest_fpstate(struct fpu_guest *gfpu, const void *buf, u64 xcr0, u32 *vpkru);
 
 static inline void fpstate_set_confidential(struct fpu_guest *gfpu)
--- a/arch/x86/kernel/fpu/core.c
+++ b/arch/x86/kernel/fpu/core.c
@@ -262,8 +262,9 @@ int fpu_swap_kvm_fpstate(struct fpu_gues
 }
 EXPORT_SYMBOL_GPL(fpu_swap_kvm_fpstate);
 
-void fpu_copy_guest_fpstate_to_uabi(struct fpu_guest *gfpu, void *buf,
-				    unsigned int size, u64 xfeatures, u32 pkru)
+void fpu_copy_guest_fpstate_to_uabi_new(struct fpu_guest *gfpu, void *buf,
+					unsigned int size, u64 xfeatures,
+					u32 pkru)
 {
 	struct fpstate *kstate = gfpu->fpstate;
 	union fpregs_state *ustate = buf;
@@ -279,6 +280,13 @@ void fpu_copy_guest_fpstate_to_uabi(stru
 		ustate->xsave.header.xfeatures = XFEATURE_MASK_FPSSE;
 	}
 }
+EXPORT_SYMBOL_GPL(fpu_copy_guest_fpstate_to_uabi_new);
+
+void fpu_copy_guest_fpstate_to_uabi(struct fpu_guest *gfpu, void *buf,
+				    unsigned int size, u32 pkru)
+{
+	fpu_copy_guest_fpstate_to_uabi_new(gfpu, buf, size, ~0, pkru);
+}
 EXPORT_SYMBOL_GPL(fpu_copy_guest_fpstate_to_uabi);
 
 int fpu_copy_uabi_to_guest_fpstate(struct fpu_guest *gfpu, const void *buf,
--- a/arch/x86/kvm/x86.c
+++ b/arch/x86/kvm/x86.c
@@ -4871,9 +4871,9 @@ static void kvm_vcpu_ioctl_x86_get_xsave
 	if (fpstate_is_confidential(&vcpu->arch.guest_fpu))
 		return;
 
-	fpu_copy_guest_fpstate_to_uabi(&vcpu->arch.guest_fpu, state, size,
-				       vcpu->arch.guest_fpu.fpstate->user_xfeatures,
-				       vcpu->arch.pkru);
+	fpu_copy_guest_fpstate_to_uabi_new(&vcpu->arch.guest_fpu, state, size,
+					   vcpu->arch.guest_fpu.fpstate->user_xfeatures,
+					   vcpu->arch.pkru);
 }
 
 static void kvm_vcpu_ioctl_x86_get_xsave(struct kvm_vcpu *vcpu,
