From: Fernando Fernandez Mancera <fmancera@suse.de>
Subject: kABI: netfilter: nft_ct: fix use-after-free in timeout object destroy
Patch-mainline: Never, kABI workaround
References: bsc#1263137 CVE-2026-31665

There are no big enough holes in the struct to insert rcu_head and cannot also
be placed at the end of the struct because there is a flexible array. Therefore
create a wrapper struct and make sure we handle it properly in init and destroy
operation.

Signed-off-by: Fernando Fernandez Mancera <fmancera@suse.de>
Reviewed-by: Jan Kara <jack@suse.cz>
---
 include/net/netfilter/nf_conntrack_timeout.h |    6 +++++-
 net/netfilter/nft_ct.c                       |   13 +++++++++----
 2 files changed, 14 insertions(+), 5 deletions(-)

--- a/include/net/netfilter/nf_conntrack_timeout.h
+++ b/include/net/netfilter/nf_conntrack_timeout.h
@@ -14,10 +14,14 @@
 struct nf_ct_timeout {
 	__u16			l3num;
 	const struct nf_conntrack_l4proto *l4proto;
-	struct rcu_head		rcu;
 	char			data[];
 };
 
+struct __nf_ct_timeout_wrapper {
+	struct rcu_head rcu;
+	struct nf_ct_timeout base;
+};
+
 struct nf_conn_timeout {
 	struct nf_ct_timeout __rcu *timeout;
 };
--- a/net/netfilter/nft_ct.c
+++ b/net/netfilter/nft_ct.c
@@ -943,6 +943,7 @@ static int nft_ct_timeout_obj_init(const
 {
 	struct nft_ct_timeout_obj *priv = nft_obj_data(obj);
 	const struct nf_conntrack_l4proto *l4proto;
+	struct __nf_ct_timeout_wrapper *wrapper;
 	struct nf_ct_timeout *timeout;
 	int l3num = ctx->family;
 	__u8 l4num;
@@ -965,12 +966,13 @@ static int nft_ct_timeout_obj_init(const
 		goto err_proto_put;
 	}
 
-	timeout = kzalloc(sizeof(struct nf_ct_timeout) +
+	wrapper = kzalloc(sizeof(struct __nf_ct_timeout_wrapper) +
 			  l4proto->ctnl_timeout.obj_size, GFP_KERNEL);
-	if (timeout == NULL) {
+	if (!wrapper) {
 		ret = -ENOMEM;
 		goto err_proto_put;
 	}
+	timeout = &wrapper->base;
 
 	ret = nft_ct_timeout_parse_policy(&timeout->data, l4proto, ctx->net,
 					  tb[NFTA_CT_TIMEOUT_DATA]);
@@ -988,7 +990,7 @@ static int nft_ct_timeout_obj_init(const
 	return 0;
 
 err_free_timeout:
-	kfree(timeout);
+	kfree(wrapper);
 err_proto_put:
 	return ret;
 }
@@ -998,11 +1000,14 @@ static void nft_ct_timeout_obj_destroy(c
 {
 	struct nft_ct_timeout_obj *priv = nft_obj_data(obj);
 	struct nf_ct_timeout *timeout = priv->timeout;
+	struct __nf_ct_timeout_wrapper *wrapper;
 
 	nf_queue_nf_hook_drop(ctx->net);
 	nf_ct_untimeout(ctx->net, timeout);
 	nf_ct_netns_put(ctx->net, ctx->family);
-	kfree_rcu(priv->timeout, rcu);
+
+	wrapper = container_of(timeout, struct __nf_ct_timeout_wrapper, base);
+	kfree_rcu(wrapper, rcu);
 }
 
 static int nft_ct_timeout_obj_dump(struct sk_buff *skb,
