From 502d9c23ff54a051c49dddcc290fa8f1eeeed4f6 Mon Sep 17 00:00:00 2001
From: Michal Suchanek <msuchanek@suse.de>
Date: Tue, 6 Aug 2024 18:10:32 +0200
Subject: [PATCH] kABI: Hide the new last_cc member in a hole in struct
 tpm_chip.

References: bsc#1082555

Technically this should not be needed. Some functions that take a
pointer to struct tpm_chip are exported and declared in public header
include/linux/tpm.h. However, the content of the structure is not. Even
for the internal users there is tpm_chip_alloc for allocating the
structure so appending to the end should also work.
---
 drivers/char/tpm/tpm.h | 4 +++-
 1 file changed, 3 insertions(+), 1 deletion(-)

diff --git a/drivers/char/tpm/tpm.h b/drivers/char/tpm/tpm.h
index 26af485dc0d7..581854f5cff3 100644
--- a/drivers/char/tpm/tpm.h
+++ b/drivers/char/tpm/tpm.h
@@ -255,8 +255,10 @@ struct tpm_chip {
 #endif /* CONFIG_ACPI */
 
 	struct tpm_space work_space;
-	u32 last_cc;
 	u32 nr_commands;
+#ifndef __GENKSYMS__
+	u32 last_cc;
+#endif
 	u32 *cc_attrs_tbl;
 
 	/* active locality */
-- 
2.46.0

