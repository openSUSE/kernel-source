From: Enzo Matsumiya <ematsumiya@suse.de>
Patch-mainline: Never, kabi fix
Subject: fix kABI breakage in NVMe driver
References: bsc#1181161

Use admin_q when __GENKSYMS__ is set. Otherwise, use the new fabrics_q member.

This is related to the changes introduced in patch
patches.suse/nvme-make-fabrics-command-run-on-a-separate-request-.patch

---
 drivers/nvme/host/fabrics.c |    6 ++++++
 drivers/nvme/host/fc.c      |    6 ++++++
 drivers/nvme/host/nvme.h    |    2 ++
 drivers/nvme/host/rdma.c    |    6 ++++++
 drivers/nvme/host/tcp.c     |    6 ++++++
 drivers/nvme/target/loop.c  |    6 ++++++
 6 files changed, 32 insertions(+)

--- a/drivers/nvme/host/fabrics.c
+++ b/drivers/nvme/host/fabrics.c
@@ -404,9 +404,15 @@ int nvmf_connect_admin_queue(struct nvme
 	strncpy(data->subsysnqn, ctrl->opts->subsysnqn, NVMF_NQN_SIZE);
 	strncpy(data->hostnqn, ctrl->opts->host->nqn, NVMF_NQN_SIZE);
 
+#ifdef __GENKSYMS__
+	ret = __nvme_submit_sync_cmd(ctrl->admin_q, &cmd, &res,
+			data, sizeof(*data), 0, NVME_QID_ANY, 1,
+			BLK_MQ_REQ_RESERVED | BLK_MQ_REQ_NOWAIT);
+#else
 	ret = __nvme_submit_sync_cmd(ctrl->fabrics_q, &cmd, &res,
 			data, sizeof(*data), 0, NVME_QID_ANY, 1,
 			BLK_MQ_REQ_RESERVED | BLK_MQ_REQ_NOWAIT);
+#endif
 	if (ret) {
 		nvmf_log_connect_error(ctrl, ret, le32_to_cpu(res.u32),
 				       &cmd, data);
--- a/drivers/nvme/host/fc.c
+++ b/drivers/nvme/host/fc.c
@@ -2047,7 +2047,9 @@ nvme_fc_ctrl_free(struct kref *ref)
 
 	blk_mq_unquiesce_queue(ctrl->ctrl.admin_q);
 	blk_cleanup_queue(ctrl->ctrl.admin_q);
+#ifndef __GENKSYMS__
 	blk_cleanup_queue(ctrl->ctrl.fabrics_q);
+#endif
 	blk_mq_free_tag_set(&ctrl->admin_tag_set);
 
 	kfree(ctrl->queues);
@@ -3153,11 +3155,13 @@ nvme_fc_init_ctrl(struct device *dev, st
 		goto out_free_queues;
 	ctrl->ctrl.admin_tagset = &ctrl->admin_tag_set;
 
+#ifndef __GENKSYMS__
 	ctrl->ctrl.fabrics_q = blk_mq_init_queue(&ctrl->admin_tag_set);
 	if (IS_ERR(ctrl->ctrl.fabrics_q)) {
 		ret = PTR_ERR(ctrl->ctrl.fabrics_q);
 		goto out_free_admin_tag_set;
 	}
+#endif
 
 	ctrl->ctrl.admin_q = blk_mq_init_queue(&ctrl->admin_tag_set);
 	if (IS_ERR(ctrl->ctrl.admin_q)) {
@@ -3233,7 +3237,9 @@ nvme_fc_init_ctrl(struct device *dev, st
 out_cleanup_admin_q:
 	blk_cleanup_queue(ctrl->ctrl.admin_q);
 out_cleanup_fabrics_q:
+#ifndef __GENKSYMS__
 	blk_cleanup_queue(ctrl->ctrl.fabrics_q);
+#endif
 out_free_admin_tag_set:
 	blk_mq_free_tag_set(&ctrl->admin_tag_set);
 out_free_queues:
--- a/drivers/nvme/host/nvme.h
+++ b/drivers/nvme/host/nvme.h
@@ -165,7 +165,9 @@ struct nvme_ctrl {
 	const struct nvme_ctrl_ops *ops;
 	struct request_queue *admin_q;
 	struct request_queue *connect_q;
+#ifndef __GENKSYMS__
 	struct request_queue *fabrics_q;
+#endif
 	struct device *dev;
 	int instance;
 	int numa_node;
--- a/drivers/nvme/host/rdma.c
